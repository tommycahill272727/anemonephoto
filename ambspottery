<script>
const canvas = document.getElementById('bg-canvas');
const ctx = canvas.getContext('2d');
let W, H, scene, tick = 0;

function rnd(a,b){return a+Math.random()*(b-a);}
function rndInt(a,b){return Math.floor(rnd(a,b));}
function pick(a){return a[Math.floor(Math.random()*a.length)];}

// ── MOUNTAIN SILHOUETTES ──────────────────────────────────
// Build layered ridgelines like the Smoky Mountains photo
function makeMountainLayer(yBase, amplitude, freq, col, alpha) {
  const pts = [{x: 0, y: yBase}];
  const steps = 80;
  for (let i = 1; i <= steps; i++) {
    const x = (i / steps) * W;
    // Multiple sine waves layered for organic shape
    const y = yBase
      - amplitude * (
          0.55 * Math.sin(i * freq * 0.9 + 1.2)
        + 0.28 * Math.sin(i * freq * 1.8 + 0.4)
        + 0.17 * Math.sin(i * freq * 3.1 + 2.1)
      );
    pts.push({x, y});
  }
  pts.push({x: W, y: yBase});
  pts.push({x: 0, y: yBase});
  return {pts, col, alpha, type:'mountain'};
}

// ── LICHEN COLONY ─────────────────────────────────────────
// Groups of small irregular ellipses clustered together
// like the round crusty colonies on the rock face photo
function makeLichenColony(cx, cy, spread, count, col, alpha) {
  const blobs = [];
  for (let i = 0; i < count; i++) {
    const angle = rnd(0, Math.PI * 2);
    const d = rnd(0, spread);
    const bx = cx + Math.cos(angle) * d;
    const by = cy + Math.sin(angle) * d * rnd(0.5, 0.9);
    const r = rnd(spread * 0.04, spread * 0.22);
    blobs.push({
      x: bx, y: by,
      rx: r * rnd(0.7, 1.8),
      ry: r * rnd(0.5, 1.2),
      rot: rnd(-Math.PI, Math.PI),
    });
  }
  return {blobs, col, alpha,
    flicker: rnd(0.003, 0.012),
    flkOff: rnd(0, Math.PI * 2),
    type: 'lichen'
  };
}

// ── ROCK CRACK ────────────────────────────────────────────
function makeCrack(x1, y1, x2, y2, col, alpha) {
  const pts = [{x:x1,y:y1}];
  const steps = rndInt(5,12);
  for (let i=1;i<steps;i++){
    const t=i/steps;
    pts.push({
      x: x1+(x2-x1)*t + rnd(-20,20),
      y: y1+(y2-y1)*t + rnd(-6,6),
    });
  }
  pts.push({x:x2,y:y2});
  return {pts, col, alpha, lw: rnd(0.4,1.6), type:'crack'};
}

// ── MOSS PATCH ────────────────────────────────────────────
// Larger irregular filled shapes — like moss spreading on bark
function makeMossPatch(cx, cy, rx, ry, col, alpha) {
  // Build as a random polygon
  const pts = [];
  const segs = rndInt(12, 22);
  for (let i = 0; i < segs; i++) {
    const a = (i / segs) * Math.PI * 2;
    const r = rnd(0.55, 1.0);
    pts.push({
      x: cx + Math.cos(a) * rx * r * rnd(0.7, 1.3),
      y: cy + Math.sin(a) * ry * r * rnd(0.7, 1.3),
    });
  }
  return {pts, cx, cy, rx, ry, col, alpha,
    flicker: rnd(0.002, 0.009),
    flkOff: rnd(0, Math.PI * 2),
    type: 'moss'
  };
}

function resize() {
  W = canvas.width = window.innerWidth;
  H = canvas.height = window.innerHeight * 3.5;
  buildScene();
}

function buildScene() {
  scene = [];
  const pageH = H;

  // ── MOUNTAIN LAYERS (bottom third of page as base)
  // Far distance — muted teal-grey (like the distant Smokies)
  scene.push(makeMountainLayer(pageH * 0.88, pageH * 0.06, 0.18, {r:38,g:72,b:55}, 0.28));
  scene.push(makeMountainLayer(pageH * 0.82, pageH * 0.08, 0.14, {r:42,g:80,b:52}, 0.32));
  scene.push(makeMountainLayer(pageH * 0.76, pageH * 0.10, 0.12, {r:50,g:90,b:55}, 0.35));
  // Mid mountains — richer green
  scene.push(makeMountainLayer(pageH * 0.70, pageH * 0.12, 0.10, {r:55,g:100,b:45}, 0.38));
  scene.push(makeMountainLayer(pageH * 0.62, pageH * 0.14, 0.09, {r:48,g:92,b:38}, 0.30));
  // Foreground ridgeline — dark forest
  scene.push(makeMountainLayer(pageH * 0.55, pageH * 0.10, 0.08, {r:30,g:55,b:25}, 0.35));

  // Also scatter mountains across upper sections of long page
  scene.push(makeMountainLayer(pageH * 0.38, pageH * 0.07, 0.15, {r:40,g:75,b:48}, 0.2));
  scene.push(makeMountainLayer(pageH * 0.33, pageH * 0.09, 0.12, {r:52,g:88,b:42}, 0.22));
  scene.push(makeMountainLayer(pageH * 0.28, pageH * 0.08, 0.10, {r:35,g:65,b:30}, 0.2));

  // ── LICHEN COLONIES — scattered across page
  // Warm chartreuse lichen (like the bright green on the dark rock)
  const lichenCols = [
    {r:115,g:168,b:58},  // bright lime lichen
    {r:95, g:148,b:48},  // mid lichen
    {r:135,g:185,b:70},  // pale lichen
    {r:80, g:128,b:42},  // deeper lichen
    {r:148,g:178,b:88},  // grey-green lichen
    {r:72, g:110,b:55},  // stone lichen
  ];
  for (let i = 0; i < 60; i++) {
    const col = pick(lichenCols);
    const spread = rnd(18, 90);
    scene.push(makeLichenColony(
      rnd(0.02, 0.98) * W,
      rnd(0.01, 0.99) * pageH,
      spread,
      rndInt(6, 20),
      col,
      rnd(0.12, 0.42)
    ));
  }

  // ── MOSS PATCHES — larger organic shapes
  const mossCols = [
    {r:58, g:110,b:32},  // vivid moss
    {r:42, g:88, b:25},  // deep moss
    {r:72, g:125,b:42},  // bright moss
    {r:35, g:70, b:22},  // dark moss
    {r:85, g:140,b:52},  // light moss
    {r:48, g:95, b:35},  // stone moss
  ];
  for (let i = 0; i < 38; i++) {
    scene.push(makeMossPatch(
      rnd(0.02, 0.98) * W,
      rnd(0.02, 0.98) * pageH,
      rnd(30, 160),
      rnd(18, 100),
      pick(mossCols),
      rnd(0.08, 0.28)
    ));
  }

  // ── ROCK CRACKS ── angular fissures like the rockface photo
  const crackCols = [
    {r:25,g:48,b:18},{r:20,g:40,b:15},{r:30,g:55,b:22}
  ];
  for (let i = 0; i < 35; i++) {
    const x = rnd(0, W), y = rnd(0, pageH);
    const len = rnd(50, 260);
    const angle = rnd(-0.5, 0.5) + (Math.random() > 0.5 ? 0 : Math.PI / 2);
    scene.push(makeCrack(
      x, y,
      x + Math.cos(angle) * len,
      y + Math.sin(angle) * len,
      pick(crackCols),
      rnd(0.12, 0.32)
    ));
  }
}

// ── DRAW FUNCTIONS ──────────────────────────────────────
function drawMountain(m) {
  if (m.pts.length < 3) return;
  ctx.save();
  ctx.beginPath();
  ctx.moveTo(m.pts[0].x, m.pts[0].y);
  for (let i = 1; i < m.pts.length; i++) ctx.lineTo(m.pts[i].x, m.pts[i].y);
  ctx.closePath();
  // Fill with gradient — lighter at ridge, darker at base (depth)
  const top = Math.min(...m.pts.map(p => p.y));
  const bot = Math.max(...m.pts.map(p => p.y));
  const g = ctx.createLinearGradient(0, top, 0, bot);
  g.addColorStop(0, `rgba(${m.col.r},${m.col.g},${m.col.b},${m.alpha})`);
  g.addColorStop(1, `rgba(${Math.max(0,m.col.r-15)},${Math.max(0,m.col.g-20)},${Math.max(0,m.col.b-10)},${m.alpha * 0.6})`);
  ctx.fillStyle = g;
  ctx.fill();
  ctx.restore();
}

function drawLichen(l) {
  const breath = 0.9 + 0.1 * Math.sin(tick * l.flicker + l.flkOff);
  const a = l.alpha * breath;
  l.blobs.forEach(b => {
    ctx.save();
    ctx.translate(b.x, b.y);
    ctx.rotate(b.rot);
    ctx.scale(1, b.ry / Math.max(b.rx, 0.1));

    // Outer soft halo
    const gOut = ctx.createRadialGradient(0,0,0,0,0,b.rx*2.5);
    gOut.addColorStop(0, `rgba(${l.col.r},${l.col.g},${l.col.b},${a*0.2})`);
    gOut.addColorStop(1, `rgba(${l.col.r},${l.col.g},${l.col.b},0)`);
    ctx.beginPath(); ctx.arc(0,0,b.rx*2.5,0,Math.PI*2);
    ctx.fillStyle = gOut; ctx.fill();

    // Dense crusty core
    const gCore = ctx.createRadialGradient(0,0,0,0,0,b.rx);
    gCore.addColorStop(0, `rgba(${Math.min(255,l.col.r+25)},${Math.min(255,l.col.g+28)},${Math.min(255,l.col.b+15)},${a})`);
    gCore.addColorStop(0.6, `rgba(${l.col.r},${l.col.g},${l.col.b},${a*0.75})`);
    gCore.addColorStop(1, `rgba(${l.col.r},${l.col.g},${l.col.b},0)`);
    ctx.beginPath(); ctx.arc(0,0,b.rx,0,Math.PI*2);
    ctx.fillStyle = gCore; ctx.fill();

    ctx.restore();
  });
}

function drawMoss(m) {
  const breath = 0.92 + 0.08 * Math.sin(tick * m.flicker + m.flkOff);
  const a = m.alpha * breath;
  if (m.pts.length < 3) return;
  ctx.save();
  ctx.beginPath();
  ctx.moveTo(m.pts[0].x, m.pts[0].y);
  for (let i = 1; i < m.pts.length; i++) ctx.lineTo(m.pts[i].x, m.pts[i].y);
  ctx.closePath();
  // Radial fill — brighter center, fading edges
  const g = ctx.createRadialGradient(m.cx, m.cy, 0, m.cx, m.cy, Math.max(m.rx, m.ry));
  g.addColorStop(0, `rgba(${Math.min(255,m.col.r+20)},${Math.min(255,m.col.g+22)},${Math.min(255,m.col.b+12)},${a})`);
  g.addColorStop(0.5, `rgba(${m.col.r},${m.col.g},${m.col.b},${a*0.7})`);
  g.addColorStop(1, `rgba(${m.col.r},${m.col.g},${m.col.b},0)`);
  ctx.fillStyle = g;
  ctx.fill();
  ctx.restore();
}

function drawCrack(c) {
  ctx.save();
  ctx.strokeStyle = `rgba(${c.col.r},${c.col.g},${c.col.b},${c.alpha})`;
  ctx.lineWidth = c.lw;
  ctx.lineCap = 'round'; ctx.lineJoin = 'round';
  ctx.beginPath();
  ctx.moveTo(c.pts[0].x, c.pts[0].y);
  for (let i=1;i<c.pts.length;i++) ctx.lineTo(c.pts[i].x, c.pts[i].y);
  ctx.stroke();
  ctx.restore();
}

function drawGrain() {
  const scanH = Math.min(H, window.innerHeight * 1.5);
  const id = ctx.getImageData(0, 0, W, scanH), d = id.data;
  for (let i = 0; i < d.length; i += 4) {
    const n = (Math.random() - 0.5) * 22;
    d[i]  =Math.max(0,Math.min(255,d[i]+n));
    d[i+1]=Math.max(0,Math.min(255,d[i+1]+n));
    d[i+2]=Math.max(0,Math.min(255,d[i+2]+n));
  }
  ctx.putImageData(id, 0, 0);
}

let last = 0;
function loop(ts) {
  if (ts - last > 58) {
    tick++;
    ctx.clearRect(0, 0, W, H);

    // Base: medium green — #1e3220 equivalent
    ctx.fillStyle = '#1e3220';
    ctx.fillRect(0, 0, W, H);

    // Subtle dappled light zones — canopy filtering
    const lights = [
      {x:0.2*W, y:0.08*H, r:350, col:{r:52,g:95,b:30}, a:0.06},
      {x:0.75*W,y:0.2*H,  r:280, col:{r:45,g:85,b:38}, a:0.05},
      {x:0.5*W, y:0.5*H,  r:400, col:{r:50,g:90,b:28}, a:0.045},
      {x:0.12*W,y:0.65*H, r:300, col:{r:42,g:80,b:35}, a:0.05},
      {x:0.85*W,y:0.8*H,  r:320, col:{r:48,g:88,b:30}, a:0.048},
    ];
    lights.forEach(l => {
      const g = ctx.createRadialGradient(l.x,l.y,0,l.x,l.y,l.r);
      g.addColorStop(0,`rgba(${l.col.r},${l.col.g},${l.col.b},${l.a})`);
      g.addColorStop(1,`rgba(${l.col.r},${l.col.g},${l.col.b},0)`);
      ctx.fillStyle=g; ctx.fillRect(0,0,W,H);
    });

    // Draw in depth order: mountains → moss → cracks → lichen
    scene.filter(s => s.type === 'mountain').forEach(drawMountain);
    scene.filter(s => s.type === 'moss').forEach(drawMoss);
    scene.filter(s => s.type === 'crack').forEach(drawCrack);
    scene.filter(s => s.type === 'lichen').forEach(drawLichen);

    drawGrain();
    last = ts;
  }
  requestAnimationFrame(loop);
}

window.addEventListener('resize', resize);
resize();
loop(0);

// ── PAGE NAV ──
function go(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('pg-' + id).classList.add('active');
  document.querySelectorAll('.nav-tabs a').forEach(a => a.classList.toggle('active', a.dataset.p === id));
  window.scrollTo({top:0,behavior:'instant'});
  setTimeout(reveal, 60);
}
function filt(btn) {
  document.querySelectorAll('.fb').forEach(b => b.classList.remove('on'));
  btn.classList.add('on');
}
function reveal() {
  const obs = new IntersectionObserver(entries => {
    entries.forEach((e,i) => {
      if (e.isIntersecting) { setTimeout(() => e.target.classList.add('in'), i*80); obs.unobserve(e.target); }
    });
  }, {threshold:0.07});
  document.querySelectorAll('.page.active .fade:not(.in)').forEach(el => obs.observe(el));
}
document.querySelectorAll('.nav-tabs a').forEach(a => { a.dataset.p = a.textContent.trim().toLowerCase(); });
reveal();
</script>
