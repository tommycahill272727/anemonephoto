</nav>

<!-- HOME -->
<div id="pg-home" class="page active">
  <section class="hero">
    <div class="hero-left">
      <div class="hero-eyebrow fade">Handmade Ceramics — Chicago</div>
      <h1 class="hero-h1 fade">Formed<br>from the<br><em>earth.</em></h1>
      <p class="hero-p fade">Each piece thrown by hand. Inspired by moss, stone, and old-growth forest. Functional objects made to be touched, used, and kept.</p>
